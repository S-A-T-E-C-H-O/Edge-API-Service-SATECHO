# SATECHO Edge — environment template. Copy to .env (or export in the shell
# that runs main.py) and fill in per deployment. Defaults shown are the ones
# hardcoded in code; they are development fallbacks, NOT production values.

# Cloud backend (Web-Service) base URL the Edge syncs to.
CLOUD_API_URL=http://localhost:8080

# Shared secret expected by the backend on /api/v1/edge/* and MQTT payloads.
# MUST match mqtt.edge.api-key (MQTT_EDGE_API_KEY) in Web-Service.
MQTT_EDGE_API_KEY=change-me

# MQTT broker shared by backend, Edge, mobile and ESP32.
# See ../docs/mqtt-contract.md — one broker per environment.
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_CLIENT_ID=agrosafe-edge

# Identity of the (single) device this Edge instance heartbeats for, and the
# zone assigned to raw ESP32 readings that carry no zone metadata.
# WARNING: these are per-deployment values — leaving the defaults (5 / 1)
# in a multi-zone farm mis-attributes every reading to zone 1.
EDGE_DEVICE_ID=5
EDGE_ZONE_ID=1

# Local SQLite buffer.
DATABASE_PATH=agrosafe_edge.db

# HTTP API.
HTTP_HOST=0.0.0.0
HTTP_PORT=5000

# Sync cadence (seconds).
SYNC_INTERVAL_SECONDS=60
HEARTBEAT_INTERVAL_SECONDS=30

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
